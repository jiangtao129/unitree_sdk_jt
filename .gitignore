# =============================================================================
# .gitignore — grouped, ordered top-of-tree first, then per-language, then
# per-tool. New additions: keep this layout (group + 1-line comment, blank
# between groups).
# =============================================================================

# --- Build output (CMake / cmake-tools) ---
build
.cache
compile_commands.json

# --- Editors / IDEs ---
.vscode
*.swp
*~

# --- Backup files (a stray *.bak.* slipped through baseline; see PR #3) ---
*.bak
*.bak.*

# --- Python ---
__pycache__/
*.pyc

# --- Logs ---
*.log

# --- Unitree SLAM specific ---
# Runtime logs rotate every run, no diff value.
unitree_slam/bin/logs/

# Built from unitree_slam/example/src/keyDemo*.cpp; don't ship binaries
# (the source is in the repo, dock rebuilds locally).
unitree_slam/bin/keyDemo
unitree_slam/bin/keyDemo[0-9]
unitree_slam/bin/keyDemo[0-9][0-9]

# Note: mid360_driver / unitree_slam / xt16_driver under unitree_slam/bin/
# are the closed-source aarch64 binaries Unitree ships (no source available).
# They are deliberately *not* ignored — see PR #5 + SECURITY.md.
